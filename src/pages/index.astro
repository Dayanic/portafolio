---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Technologies from '../components/Technologies.astro';
import Skills from '../components/Skills.astro';
import Projects from '../components/Projects.astro';
import ProjectModal from '../components/ProjectModal.astro';
import Experience from '../components/Experience.astro';
import Certificates from '../components/Certificates.astro';
import type { IRawPortfolioData } from '../types/portfolio';
import { resolveData } from '../i18n/resolve';
import rawData from '../data/data.json';

const raw = rawData as unknown as IRawPortfolioData;
const es = resolveData(raw, 'es');
const en = resolveData(raw, 'en');
---

<BaseLayout esMeta={es.meta} enMeta={en.meta}>
  <Header />

  <main>
    <!--
      Cada sección tiene un id único aquí (para que los anchor links del nav funcionen).
      Dentro, dos bloques data-lang: CSS muestra solo el activo sin recarga de página.
    -->

    <div id="hero">
      <div data-lang="es"><Hero hero={es.hero} lang="es" /></div>
      <div data-lang="en"><Hero hero={en.hero} lang="en" /></div>
    </div>

    <div id="about">
      <div data-lang="es"><About about={es.about} lang="es" /></div>
      <div data-lang="en"><About about={en.about} lang="en" /></div>
    </div>

    <div id="technologies">
      <div data-lang="es"><Technologies technologies={es.technologies} lang="es" /></div>
      <div data-lang="en"><Technologies technologies={en.technologies} lang="en" /></div>
    </div>

    <div id="skills">
      <div data-lang="es"><Skills skills={es.skills} lang="es" /></div>
      <div data-lang="en"><Skills skills={en.skills} lang="en" /></div>
    </div>

    <div id="projects">
      <div data-lang="es"><Projects projects={es.projects} lang="es" /></div>
      <div data-lang="en"><Projects projects={en.projects} lang="en" /></div>
    </div>

    <div id="experience">
      <div data-lang="es"><Experience experience={es.experience} lang="es" /></div>
      <div data-lang="en"><Experience experience={en.experience} lang="en" /></div>
    </div>

    <div id="certificates">
      <div data-lang="es"><Certificates certificates={es.certificates} lang="es" /></div>
      <div data-lang="en"><Certificates certificates={en.certificates} lang="en" /></div>
    </div>

  </main>

  <footer class="border-t border-slate-200 dark:border-violet-500/40 py-8 text-center text-sm text-slate-500 dark:text-slate-400">
    <div data-lang="es">© {new Date().getFullYear()} Todos los derechos reservados.</div>
    <div data-lang="en">© {new Date().getFullYear()} All rights reserved.</div>
  </footer>

  <!-- Modal único: detecta idioma activo en runtime -->
  <ProjectModal />
</BaseLayout>
