---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Technologies from '../components/Technologies.astro';
import Skills from '../components/Skills.astro';
import Projects from '../components/Projects.astro';
import ProjectModal from '../components/ProjectModal.astro';
import Experience from '../components/Experience.astro';
import Certificates from '../components/Certificates.astro';
import type { IRawPortfolioData } from '../types/portfolio';
import { resolveData } from '../i18n/resolve';
import rawData from '../data/data.json';

const raw = rawData as unknown as IRawPortfolioData;
const data = { es: resolveData(raw, 'es'), en: resolveData(raw, 'en') };
const langs = (['es', 'en'] as const).map(l => ({ lang: l, d: data[l] }));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: data.es.hero.name,
  jobTitle: data.es.hero.title,
  url: data.es.meta.url,
  image: `${data.es.meta.url}${data.es.hero.avatar}`,
  sameAs: [data.es.hero.linkedin, data.es.social.github],
};
---

<BaseLayout esMeta={data.es.meta} enMeta={data.en.meta}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <Header />

  <main>
    <!--
      Cada sección tiene un id único (para anchor links del nav).
      Dentro, dos bloques data-lang: CSS muestra solo el activo sin recarga.
    -->

    <div id="hero">
      {langs.map(({ lang, d }) => <div data-lang={lang}><Hero hero={d.hero} lang={lang} /></div>)}
    </div>

    <div id="about">
      {langs.map(({ lang, d }) => <div data-lang={lang}><About about={d.about} lang={lang} /></div>)}
    </div>

    <div id="technologies">
      {langs.map(({ lang, d }) => <div data-lang={lang}><Technologies technologies={d.technologies} lang={lang} /></div>)}
    </div>

    <div id="skills">
      {langs.map(({ lang, d }) => <div data-lang={lang}><Skills skills={d.skills} lang={lang} /></div>)}
    </div>

    <div id="projects">
      {langs.map(({ lang, d }) => <div data-lang={lang}><Projects projects={d.projects} lang={lang} /></div>)}
    </div>

    <div id="experience">
      {langs.map(({ lang, d }) => <div data-lang={lang}><Experience experience={d.experience} lang={lang} /></div>)}
    </div>

    <div id="certificates">
      {langs.map(({ lang, d }) => <div data-lang={lang}><Certificates certificates={d.certificates} lang={lang} /></div>)}
    </div>
  </main>

  <footer class="border-t border-slate-200 dark:border-violet-500/40 py-8 text-center text-sm text-slate-500 dark:text-slate-400">
    <div data-lang="es">© {new Date().getFullYear()} Todos los derechos reservados.</div>
    <div data-lang="en">© {new Date().getFullYear()} All rights reserved.</div>
  </footer>

  <!-- Modal único: detecta idioma activo en runtime -->
  <ProjectModal />
</BaseLayout>
