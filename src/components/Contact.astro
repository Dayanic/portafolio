---
import type { IContact } from '../types/portfolio';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  contact: IContact;
  lang: Lang;
}

const { contact, lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="py-20 bg-white dark:bg-[#1a0030]/40">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="animate-on-scroll">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-slate-50 mb-2">
        {t('contact.title')}
      </h2>
      <div class="w-16 h-1 bg-violet-500 rounded-full mb-10"></div>
    </div>

    <div class="flex flex-col sm:flex-row flex-wrap gap-6 animate-on-scroll">
      <!-- Email -->
      <a
        href={`mailto:${contact.email}`}
        class="group flex items-center gap-4 bg-white dark:bg-[#180028] rounded-2xl px-6 py-5 shadow-sm border border-slate-100 dark:border-violet-500/40 hover:shadow-md hover:-translate-y-1 transition-all duration-300"
      >
        <div class="w-12 h-12 bg-violet-500/10 dark:bg-violet-500/20 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-violet-500/20 dark:group-hover:bg-violet-500/30 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-violet-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <div>
          <p class="text-xs text-slate-500 dark:text-slate-400 mb-0.5">{t('contact.email')}</p>
          <p class="font-medium text-slate-900 dark:text-slate-100 group-hover:text-violet-500 dark:group-hover:text-violet-400 transition-colors">{contact.email}</p>
        </div>
      </a>

      <!-- LinkedIn -->
      <a
        href={contact.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-4 bg-white dark:bg-[#180028] rounded-2xl px-6 py-5 shadow-sm border border-slate-100 dark:border-violet-500/40 hover:shadow-md hover:-translate-y-1 transition-all duration-300"
      >
        <div class="w-12 h-12 bg-violet-500/10 dark:bg-violet-500/20 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-violet-500/20 dark:group-hover:bg-violet-500/30 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-violet-500" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </div>
        <div>
          <p class="text-xs text-slate-500 dark:text-slate-400 mb-0.5">{t('contact.linkedin')}</p>
          <p class="font-medium text-slate-900 dark:text-slate-100 group-hover:text-violet-500 dark:group-hover:text-violet-400 transition-colors">
            in/dayanecoronado
          </p>
        </div>
      </a>

      <!-- GitHub (conditional) -->
      {contact.showGithub && (
        <a
          href={contact.github}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-4 bg-white dark:bg-[#180028] rounded-2xl px-6 py-5 shadow-sm border border-slate-100 dark:border-violet-500/40 hover:shadow-md hover:-translate-y-1 transition-all duration-300"
        >
          <div class="w-12 h-12 bg-violet-500/10 dark:bg-violet-500/20 rounded-xl flex items-center justify-center flex-shrink-0 group-hover:bg-violet-500/20 dark:group-hover:bg-violet-500/30 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-violet-500" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs text-slate-500 dark:text-slate-400 mb-0.5">{t('contact.github')}</p>
            <p class="font-medium text-slate-900 dark:text-slate-100 group-hover:text-violet-500 dark:group-hover:text-violet-400 transition-colors">
              github.com/Dayanic
            </p>
          </div>
        </a>
      )}
    </div>

    <!-- Footer -->
    <footer class="mt-20 pt-8 border-t border-slate-200 dark:border-violet-500/40 text-center animate-on-scroll">
      <p class="text-sm text-slate-500 dark:text-slate-400">
        © {new Date().getFullYear()} {t('footer.rights')}
      </p>
    </footer>
  </div>
</section>
