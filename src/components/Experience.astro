---
import type { IExperience } from '../types/portfolio';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  experience: IExperience[];
  lang: Lang;
}

const { experience, lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="py-20 bg-white dark:bg-[#1a0030]/40">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="animate-on-scroll">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-slate-50 mb-2">
        {t('experience.title')}
      </h2>
      <div class="w-16 h-1 bg-violet-500 rounded-full mb-10"></div>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <ol class="flex flex-col gap-10" role="list">
        {experience.map((job) => (
          <li class="exp-item relative pl-12 sm:pl-20 animate-on-scroll">
            <!-- Dot -->
            <div class="exp-dot absolute left-3 sm:left-7 top-1.5 w-3 h-3 rounded-full border-2" aria-hidden="true"></div>

            <!-- Card -->
            <article class="bg-white dark:bg-[#180028] rounded-2xl p-5 sm:p-6 shadow-sm border border-slate-100 dark:border-violet-500/40">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
                <div>
                  <h3 class="font-bold text-slate-900 dark:text-slate-50 text-lg">{job.role}</h3>
                  <p class="text-violet-500 dark:text-violet-400 font-medium text-sm">{job.company}</p>
                </div>
                <span class={`flex-shrink-0 text-xs font-semibold px-3 py-1.5 rounded-full self-start sm:self-auto border ${
                  job.current
                    ? 'bg-violet-100 text-violet-700 border-violet-300 dark:bg-violet-500/20 dark:text-violet-300 dark:border-violet-500/40'
                    : 'bg-violet-50 text-violet-400 border-violet-200 dark:bg-[#220038] dark:text-violet-400/60 dark:border-violet-500/30'
                }`}>
                  {job.startDate} — {job.current ? t('experience.present') : job.endDate}
                </span>
              </div>

              <ul class="flex flex-col gap-1.5 mt-1">
                {job.description.map((item) => (
                  <li class="flex items-start gap-2 text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-violet-500 flex-shrink-0" aria-hidden="true"></span>
                    {item}
                  </li>
                ))}
              </ul>
            </article>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style is:global>
  .exp-item {
    transition: opacity 0.5s ease;
  }
  /* Una vez animada la entrada, la opacidad base es reducida */
  .exp-item.animate-on-scroll.is-visible {
    opacity: 0.45;
  }
  /* La entrada activa (en zona de lectura) recupera opacidad total */
  .exp-item.animate-on-scroll.is-visible.is-active {
    opacity: 1;
  }
  /* Línea que conecta exactamente centro-dot a centro-dot */
  .exp-item:not(:last-child)::before {
    content: '';
    position: absolute;
    left: 1.125rem;
    top: 1.125rem;         /* borde inferior del dot: top-1.5 (0.375rem) + h-3 (0.75rem) */
    height: calc(100% + 1.75rem); /* llega al borde superior del siguiente dot */
    width: 1px;
    background-color: #e9d5ff;
  }
  @media (min-width: 640px) {
    .exp-item:not(:last-child)::before {
      left: 2.125rem;
    }
  }
  html.dark .exp-item:not(:last-child)::before {
    background-color: #3d0060;
  }

  .exp-dot {
    background-color: transparent;
    border-color: rgb(124 58 237 / 0.3);
    transition: background-color 0.4s ease, border-color 0.4s ease;
  }
  .exp-item.is-active .exp-dot {
    background-color: rgb(124 58 237);
    border-color: rgb(124 58 237);
  }
</style>

<script>
  const expItems = Array.from(document.querySelectorAll<HTMLElement>('.exp-item'));

  function updateActive(): void {
    // Punto focal: 35% desde el tope del viewport
    const focal = window.scrollY + window.innerHeight * 0.35;

    let activeItem: HTMLElement | null = null;
    let minDist = Infinity;

    expItems.forEach((item) => {
      // Ignorar items sin animar aún y los del idioma oculto (display:none)
      if (!item.classList.contains('is-visible') || item.offsetParent === null) return;
      const rect = item.getBoundingClientRect();
      // Solo items que estén al menos parcialmente en pantalla
      if (rect.bottom < 0 || rect.top > window.innerHeight) return;
      const dist = Math.abs(focal - (rect.top + window.scrollY));
      if (dist < minDist) {
        minDist = dist;
        activeItem = item;
      }
    });

    expItems.forEach((item) => {
      if (item === activeItem) {
        item.classList.add('is-active');
      } else {
        item.classList.remove('is-active');
      }
    });
  }

  window.addEventListener('scroll', updateActive, { passive: true });
  // Ejecutar tras las animaciones de entrada
  setTimeout(updateActive, 700);
</script>
