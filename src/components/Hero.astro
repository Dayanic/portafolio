---
import type { IHero } from '../types/portfolio';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  hero: IHero;
  lang: Lang;
}

const { hero, lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="min-h-[60vh] flex items-center py-12">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="flex flex-col-reverse lg:flex-row items-center gap-12 lg:gap-16">
      <!-- Text content -->
      <div class="flex-1 text-center lg:text-left animate-on-scroll">
        <p class="text-violet-500 dark:text-violet-400 font-semibold text-sm uppercase tracking-widest mb-3">
          {hero.title}
        </p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 dark:text-slate-50 leading-tight mb-4">
          {hero.name}
        </h1>

        <!-- Rotating roles -->
        <div class="h-8 mb-6 overflow-hidden">
          <ul class="roles-list text-lg sm:text-xl text-slate-600 dark:text-slate-400 font-medium">
            {hero.roles.map((role, i) => (
              <li class={`role-item transition-all duration-500 ${i === 0 ? 'opacity-100' : 'opacity-0 absolute'}`}>
                {role}
              </li>
            ))}
          </ul>
        </div>

        <!-- Location -->
        <p class="flex items-center justify-center lg:justify-start gap-2 text-slate-500 dark:text-violet-400 text-sm mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          {hero.location}
        </p>

        <!-- Badge: experience -->
        <div class="flex items-center justify-center lg:justify-start mb-8">
          <span class="inline-flex items-center gap-1.5 px-4 py-2 bg-violet-50 dark:bg-violet-500/10 text-violet-700 dark:text-violet-400 text-sm font-semibold rounded-full border border-violet-200 dark:border-violet-500/30">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            {hero.yearsExperience}+ {t('hero.years_experience')}
          </span>
        </div>

      </div>

      <!-- Avatar -->
      <div class="flex-shrink-0 animate-on-scroll">
        <div class="relative w-48 h-48 sm:w-64 sm:h-64 lg:w-72 lg:h-72">
          <div class="avatar-glow absolute inset-0 rounded-full bg-gradient-to-br from-violet-400 to-violet-700 blur-2xl opacity-20"></div>
          <img
            src={hero.avatar}
            alt={hero.name}
            class="avatar-img relative w-full h-full object-cover object-center rounded-full border-4 border-violet-500/30 shadow-2xl"
            loading="eager"
            onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect fill=%22%231e293b%22 width=%22100%22 height=%22100%22 rx=%2250%22/><text x=%2250%22 y=%2265%22 font-size=%2240%22 text-anchor=%22middle%22 fill=%22%237c3aed%22>DCG</text></svg>'"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  @keyframes avatar-glow-pulse {
    0%, 100% { opacity: 0.15; transform: scale(0.90); }
    50%       { opacity: 0.55; transform: scale(1.10); }
  }

  @keyframes avatar-border-pulse {
    0%, 100% { box-shadow: 0 0 0px  0px rgb(139 92 246 / 0);    }
    50%       { box-shadow: 0 0 28px 8px rgb(139 92 246 / 0.30); }
  }

  /* Dark mode — glow intenso */
  html.dark .avatar-glow {
    animation: avatar-glow-pulse 2s ease-in-out infinite;
  }
  html.dark .avatar-img {
    animation: avatar-border-pulse 2s ease-in-out infinite;
  }

  /* Light mode — glow muy sutil */
  @keyframes avatar-glow-pulse-light {
    0%, 100% { opacity: 0.08; transform: scale(0.92); }
    50%       { opacity: 0.28; transform: scale(1.06); }
  }
  @keyframes avatar-border-pulse-light {
    0%, 100% { box-shadow: 0 0 0px  0px rgb(124 58 237 / 0);    }
    50%       { box-shadow: 0 0 18px 5px rgb(124 58 237 / 0.12); }
  }
  html:not(.dark) .avatar-glow {
    animation: avatar-glow-pulse-light 2s ease-in-out infinite;
  }
  html:not(.dark) .avatar-img {
    animation: avatar-border-pulse-light 2s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .avatar-glow,
    .avatar-img { animation: none !important; }
  }
</style>

<script>
  document.querySelectorAll('.roles-list').forEach((list) => {
    const items = list.querySelectorAll('.role-item');
    let current = 0;
    if (items.length > 1) {
      setInterval(() => {
        items[current].classList.remove('opacity-100');
        items[current].classList.add('opacity-0');
        current = (current + 1) % items.length;
        items[current].classList.remove('opacity-0');
        items[current].classList.add('opacity-100');
      }, 3000);
    }
  });
</script>
