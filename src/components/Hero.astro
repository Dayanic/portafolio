---
import type { IHero } from '../types/portfolio';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  hero: IHero;
  lang: Lang;
}

const { hero, lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="min-h-[calc(100vh-4rem)] flex items-center py-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="flex flex-col-reverse lg:flex-row items-center gap-12 lg:gap-16">
      <!-- Text content -->
      <div class="flex-1 text-center lg:text-left animate-on-scroll">
        <p class="text-teal-500 dark:text-teal-400 font-semibold text-sm uppercase tracking-widest mb-3">
          {hero.title}
        </p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 dark:text-slate-50 leading-tight mb-4">
          {hero.name}
        </h1>

        <!-- Rotating roles -->
        <div class="h-8 mb-6 overflow-hidden">
          <ul class="roles-list text-lg sm:text-xl text-slate-600 dark:text-slate-400 font-medium">
            {hero.roles.map((role, i) => (
              <li class={`role-item transition-all duration-500 ${i === 0 ? 'opacity-100' : 'opacity-0 absolute'}`}>
                {role}
              </li>
            ))}
          </ul>
        </div>

        <!-- Location -->
        <p class="flex items-center justify-center lg:justify-start gap-2 text-slate-500 dark:text-slate-500 text-sm mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          {hero.location}
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4">
          {hero.cvAvailable ? (
            <a
              href={hero.cv}
              download
              class="inline-flex items-center gap-2 px-6 py-3 bg-teal-500 hover:bg-teal-600 text-white font-semibold rounded-xl transition-colors shadow-lg shadow-teal-500/20"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              {t('hero.download_cv')}
            </a>
          ) : (
            <span class="inline-flex items-center gap-2 px-6 py-3 bg-slate-200 dark:bg-slate-700 text-slate-500 dark:text-slate-400 font-semibold rounded-xl cursor-not-allowed select-none">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              {t('hero.cv_soon')}
            </span>
          )}

          <a
            href="#contact"
            class="inline-flex items-center gap-2 px-6 py-3 border-2 border-teal-500 dark:border-teal-400 text-teal-500 dark:text-teal-400 hover:bg-teal-500 hover:text-white dark:hover:bg-teal-400 dark:hover:text-slate-900 font-semibold rounded-xl transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            {t('hero.contact')}
          </a>
        </div>
      </div>

      <!-- Avatar -->
      <div class="flex-shrink-0 animate-on-scroll">
        <div class="relative w-48 h-48 sm:w-64 sm:h-64 lg:w-72 lg:h-72">
          <div class="absolute inset-0 rounded-full bg-gradient-to-br from-teal-400 to-teal-600 blur-2xl opacity-20"></div>
          <img
            src={hero.avatar}
            alt={hero.name}
            class="relative w-full h-full object-cover rounded-full border-4 border-teal-500/30 shadow-2xl"
            loading="eager"
            onerror="this.src='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect fill=%22%231e293b%22 width=%22100%22 height=%22100%22 rx=%2250%22/><text x=%2250%22 y=%2265%22 font-size=%2240%22 text-anchor=%22middle%22 fill=%22%2314b8a6%22>DCG</text></svg>'"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.roles-list').forEach((list) => {
    const items = list.querySelectorAll('.role-item');
    let current = 0;
    if (items.length > 1) {
      setInterval(() => {
        items[current].classList.remove('opacity-100');
        items[current].classList.add('opacity-0');
        current = (current + 1) % items.length;
        items[current].classList.remove('opacity-0');
        items[current].classList.add('opacity-100');
      }, 3000);
    }
  });
</script>
