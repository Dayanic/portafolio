---
import type { IProject } from '../types/portfolio';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  projects: IProject[];
  lang: Lang;
}

const { projects, lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="animate-on-scroll">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-slate-50 mb-2">
        {t('projects.title')}
      </h2>
      <div class="w-16 h-1 bg-violet-500 rounded-full mb-10"></div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <article
          class="animate-on-scroll group bg-white dark:bg-[#180028] rounded-2xl p-6 flex flex-col gap-4 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 border border-slate-100 dark:border-[#3d0060]/50 cursor-pointer focus:outline-none focus:ring-2 focus:ring-violet-500 focus:ring-offset-2 dark:focus:ring-offset-slate-900"
          data-project={JSON.stringify(project)}
          tabindex="0"
          role="button"
          aria-label={`Ver detalles de ${project.title}`}
        >
          <!-- Year badge -->
          <div class="flex items-center justify-between">
            <span class="text-xs font-semibold text-violet-500 uppercase tracking-widest">{project.year}</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-400 group-hover:text-violet-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </div>

          <!-- Title & role -->
          <div>
            <h3 class="font-bold text-slate-900 dark:text-slate-50 text-lg leading-tight mb-1 group-hover:text-violet-500 dark:group-hover:text-violet-400 transition-colors">
              {project.title}
            </h3>
            <p class="text-xs text-slate-500 dark:text-slate-400">{project.role}</p>
          </div>

          <!-- Summary -->
          <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed flex-1">
            {project.summary}
          </p>

          <!-- Technologies -->
          <div class="flex flex-wrap gap-2">
            {project.technologies.slice(0, 3).map((tech) => (
              <span class="px-2 py-0.5 text-xs font-medium bg-slate-100 dark:bg-[#220038] text-slate-600 dark:text-slate-400 rounded-full">
                {tech}
              </span>
            ))}
            {project.technologies.length > 3 && (
              <span class="px-2 py-0.5 text-xs font-medium bg-slate-100 dark:bg-[#220038] text-slate-500 dark:text-slate-500 rounded-full">
                +{project.technologies.length - 3}
              </span>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
