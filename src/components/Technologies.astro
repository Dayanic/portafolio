---
import { Icon } from 'astro-icon/components';
import type { ITechnology } from '../types/portfolio';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  technologies: ITechnology[];
  lang: Lang;
}

const { technologies, lang } = Astro.props;
const t = useTranslations(lang);

const techIconMap: Record<string, string> = {
  'HTML':                                   'devicon:html5',
  'JavaScript':                             'devicon:javascript',
  'C#':                                     'devicon:csharp',
  'VB.NET':                                 'devicon:visualbasic',
  'Oracle PL/SQL':                          'devicon:oracle',
  'SQL Server':                             'simple-icons:microsoftsqlserver',
  'PostgreSQL':                             'devicon:postgresql',
  'NPM':                                    'devicon:npm-wordmark',
  'REST API':                               'devicon:swagger',
  'JIRA':                                   'simple-icons:jira',
  'Git / GitHub':                           'devicon:git',
  'Azure DevOps CI/CD pipelines':           'simple-icons:azuredevops',
  'Team Foundation Version Control (TFVC)': 'devicon:visualstudio',
  'SVN (Subversion)':                       'devicon:subversion',
};

const simpleIconsNames = new Set([
  'simple-icons:jira',
  'simple-icons:microsoftsqlserver',
  'simple-icons:azuredevops',
]);
---

<section class="py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="animate-on-scroll">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-slate-50 mb-2">
        {t('technologies.title')}
      </h2>
      <div class="w-16 h-1 bg-violet-500 rounded-full mb-10"></div>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
      {technologies.map((tech) => (
        <div class="animate-on-scroll bg-white dark:bg-[#180028] rounded-2xl p-4 flex flex-col gap-3 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 border border-slate-100 dark:border-violet-500/40">
          <div class="w-8 h-8 flex items-center justify-center" aria-hidden="true">
            {tech.name === 'ServiceNow' ? (
              /* ServiceNow: logo oficial no disponible en paquetes gratuitos — SVG inline de su marca */
              <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" class="w-8 h-8">
                <circle cx="16" cy="16" r="16" fill="#81b5a1"/>
                <circle cx="16" cy="16" r="10" fill="none" stroke="white" stroke-width="3"/>
                <circle cx="16" cy="16" r="4" fill="white"/>
              </svg>
            ) : techIconMap[tech.name] ? (
              <Icon
                name={techIconMap[tech.name]}
                class={`w-8 h-8 ${simpleIconsNames.has(techIconMap[tech.name]) ? 'text-violet-500 dark:text-violet-400' : ''}`}
              />
            ) : null}
          </div>
          <p class="font-semibold text-slate-800 dark:text-slate-200 text-sm leading-tight">
            {tech.name}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
