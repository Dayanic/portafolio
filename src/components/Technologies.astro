---
import type { ITechnology } from '../types/portfolio';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  technologies: ITechnology[];
  lang: Lang;
}

const { technologies, lang } = Astro.props;
const t = useTranslations(lang);

const levelColor: Record<string, string> = {
  experto: 'bg-teal-500/20 text-teal-600 dark:text-teal-400 border border-teal-500/30',
  expert: 'bg-teal-500/20 text-teal-600 dark:text-teal-400 border border-teal-500/30',
  intermedio: 'bg-blue-500/20 text-blue-600 dark:text-blue-400 border border-blue-500/30',
  intermediate: 'bg-blue-500/20 text-blue-600 dark:text-blue-400 border border-blue-500/30',
  aprendiendo: 'bg-amber-500/20 text-amber-600 dark:text-amber-400 border border-amber-500/30',
  learning: 'bg-amber-500/20 text-amber-600 dark:text-amber-400 border border-amber-500/30',
};

const categoryIcon: Record<string, string> = {
  backend: '⚙️',
  frontend: '🎨',
  devops: '🔧',
  cloud: '☁️',
  database: '🗄️',
  other: '📦',
};

function getLevelLabel(level: string): string {
  const key = `technologies.level.${level}` as Parameters<typeof t>[0];
  return t(key);
}
---

<section class="py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="animate-on-scroll">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-slate-50 mb-2">
        {t('technologies.title')}
      </h2>
      <div class="w-16 h-1 bg-teal-500 rounded-full mb-10"></div>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
      {technologies.map((tech) => (
        <div class="animate-on-scroll bg-white dark:bg-slate-800 rounded-2xl p-4 flex flex-col gap-3 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 border border-slate-100 dark:border-slate-700">
          <div class="flex items-center justify-between">
            <span class="text-xl" aria-hidden="true">{categoryIcon[tech.category] ?? '📦'}</span>
            <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${levelColor[tech.level] ?? ''}`}>
              {getLevelLabel(tech.level)}
            </span>
          </div>
          <p class="font-semibold text-slate-800 dark:text-slate-200 text-sm leading-tight">
            {tech.name}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
