---
import type { IAbout } from '../types/portfolio';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  about: IAbout;
  lang: Lang;
}

const { about, lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="py-20 bg-white dark:bg-[#1a0030]/40">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="animate-on-scroll">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-slate-50 mb-2">
        {t('about.title')}
      </h2>
      <div class="w-16 h-1 bg-violet-500 rounded-full mb-10"></div>
    </div>

    <div class="max-w-4xl animate-on-scroll">
      <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed">
        {about.summary}
      </p>
    </div>
  </div>
</section>
