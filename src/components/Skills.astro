---
import { Icon } from 'astro-icon/components';
import type { ISkills } from '../types/portfolio';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  skills: ISkills;
  lang: Lang;
}

const { skills, lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="py-20 bg-white dark:bg-[#1a0030]/40">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="animate-on-scroll">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-slate-50 mb-2">
        {t('skills.title')}
      </h2>
      <div class="w-16 h-1 bg-violet-500 rounded-full mb-10"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-12">
      <!-- Technical skills -->
      <div class="animate-on-scroll">
        <h3 class="text-lg font-semibold text-slate-700 dark:text-slate-300 mb-6 flex items-center gap-2">
          <span class="w-2 h-2 bg-violet-600 rounded-full" aria-hidden="true"></span>
          {t('skills.technical')}
        </h3>
        <ul class="grid grid-cols-2 gap-2" role="list">
          {skills.technical.map((skill) => (
            <li class="flex">
              <span class="inline-flex items-center gap-2 w-full px-4 py-2 text-sm font-medium text-slate-700 dark:text-slate-200 bg-slate-100 dark:bg-[#220038] border border-slate-200 dark:border-violet-500/40 rounded-full">
                <Icon name={skill.icon} class="w-4 h-4 text-violet-500 dark:text-violet-400 shrink-0" aria-hidden="true" />
                {skill.name}
              </span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Soft skills -->
      <div class="animate-on-scroll">
        <h3 class="text-lg font-semibold text-slate-700 dark:text-slate-300 mb-6 flex items-center gap-2">
          <span class="w-2 h-2 bg-violet-600 rounded-full" aria-hidden="true"></span>
          {t('skills.soft')}
        </h3>
        <ul class="grid grid-cols-2 gap-2" role="list">
          {skills.soft.map((skill) => (
            <li class="flex">
              <span class="inline-flex items-center gap-2 w-full px-4 py-2 text-sm font-medium text-slate-700 dark:text-slate-200 bg-slate-100 dark:bg-[#220038] border border-slate-200 dark:border-violet-500/40 rounded-full">
                <Icon name={skill.icon} class="w-4 h-4 text-violet-500 dark:text-violet-400 shrink-0" aria-hidden="true" />
                {skill.name}
              </span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
